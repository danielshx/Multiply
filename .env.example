# =============================================================================
# Multiply — Swarm Outreach Engine (HappyRobot × TUM.ai)
# Copy to .env.local and fill in. Never commit real secrets.
# =============================================================================

# --- HappyRobot (EU region) ---------------------------------------------------
# HR_API_KEY is also forwarded to the @happyrobot-ai/mcp server as HAPPYROBOT_API_KEY via ../.mcp.json
HR_API_KEY=
HR_WORKFLOW_SLUG=019d9cb9-416e-7404-be97-3d329afb1318
HR_BASE_URL=https://api.eu.happyrobot.ai/v2
HR_HOOKS_URL=https://platform.eu.happyrobot.ai/hooks
WEBHOOK_SECRET=

# --- Cognee (knowledge graph + vector memory) --------------------------------
# Self-hosted via docker-compose.cognee.yml (default), or Cognee Cloud.
COGNEE_API_URL=http://localhost:8000
COGNEE_API_KEY=
# OpenAI key cognee uses internally for LLM + embeddings (required for self-host).
COGNEE_LLM_API_KEY=

# --- HappyRobot Twin DB (workflow dump + learnings) ---------------------------
HR_TWIN_BASE_URL=
HR_TWIN_API_KEY=
HR_TWIN_WORKFLOW_DUMP_TABLE=workflow_dump
HR_TWIN_LEARNINGS_TABLE=learnings

# --- Supabase -----------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE=

# --- Google Calendar (booking tool) -------------------------------------------
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REFRESH_TOKEN=
DEMO_CALENDAR_ID=

# --- Email Agent (sender identity for the cold-lead branch of the Watcher) ----
# All outbound emails from the Email Agent must be sent from this address.
EMAIL_AGENT_FROM=happymultiply@gmail.com
# Gmail App Password — generate at https://myaccount.google.com/apppasswords
# (account must have 2-Step Verification enabled). 16 chars, spaces stripped.
# If empty, /api/watcher/trigger-email falls back to STUB mode.
GMAIL_APP_PASSWORD=

# --- HR runtime environment for Mini Voice Agent runs -------------------------
# 'staging' is currently the only environment with a working outbound voice
# trunk for this org (production trunk is broken HR-side, 2026-04-18).
HR_MINI_ENVIRONMENT=staging

# --- SMS Agent on/off switch --------------------------------------------------
# HR org's Twilio sub-account credentials are currently invalid. While false,
# /api/watcher/trigger-sms logs and falls back to /api/watcher/trigger-email.
# Set true once Twilio creds are fixed in HR.
SMS_ENABLED=false

# --- Demo ---------------------------------------------------------------------
DEMO_PRODUCT_PROFILE_PATH=./scripts/product-profile.json
NEXT_PUBLIC_APP_URL=http://localhost:3000
